MONGO_URL="mongodb://localhost:27017"
DB_NAME="gzen_demo"

# JWT — generate a strong random string for production (e.g., `openssl rand -hex 32`)
JWT_SECRET="REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING"

# Demo / admin user — idempotently seeded on startup
ADMIN_EMAIL="ansh@gzen.app"
ADMIN_PASSWORD="gzen1234"

# Emergent LLM key (Gemini / GPT / Claude). Get from your Emergent profile.
# Or replace ai_service.py to use your own provider key directly.
EMERGENT_LLM_KEY="REPLACE_WITH_YOUR_EMERGENT_LLM_KEY"

# Frontend URL for CORS — set to your real origin in production
FRONTEND_URL="http://localhost:8081"
